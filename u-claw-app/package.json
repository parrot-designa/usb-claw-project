{
  "name": "u-claw",
  "version": "1.0.0",
  "description": "Openclaw - AI 助手桌面版，插上 U 盘就能用",
  "main": "dist/main/index.js",
  "author": "wjb",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development chcp 65001 > nul & electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "build:mac": "NODE_ENV=production electron-vite build && electron-builder --mac",
    "build:win": "cross-env NODE_ENV=production electron-vite build && electron-builder --win",
    "build:win32": "cross-env NODE_ENV=production electron-vite build && electron-builder --win --ia32",
    "build:all": "electron-vite build && electron-builder --mac --win",
    "build:mac-arm64": "NODE_ENV=production electron-vite build && electron-builder --mac --arm64",
    "build:mac-x64": "electron-vite build && electron-builder --mac --x64",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "pinia": "^2.1.0",
    "qrcode": "^1.5.4",
    "vue": "^3.5.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^2.3.0",
    "javascript-obfuscator": "^5.4.2",
    "sass": "^1.99.0",
    "vite": "^5.4.0"
  }
}
